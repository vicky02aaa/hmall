# ============================================
# Maven - Java 构建工具
# ============================================
target/                          # Maven 编译输出目录

# ============================================
# IDE - IntelliJ IDEA（主要开发工具）
# ============================================
.idea/                           # IDEA 项目配置目录
*.iml                            # IDEA 模块文件

# ============================================
# Logs - 日志文件
# ============================================
logs/                            # 项目日志目录（所有微服务日志）
*.log                            # 日志文件

# ============================================
# Nacos - 配置中心缓存
# ============================================
config-cache/          # Nacos 配置缓存目录
snapshot/              # Nacos 快照目录

# ============================================
# Application Configurations - 应用配置文件（包含敏感信息）
# ============================================
**/application-local.yaml    # 本地开发配置（数据库密码等）

# ============================================
# Secrets and Keys - 密钥和证书文件（绝对不能提交）
# ============================================
*.jks                # Java KeyStore 密钥库（JWT签名密钥）

# ============================================
# Notes:
# 这是 HMall 电商微服务项目的 .gitignore 配置
# 已忽略：本地配置文件、密钥文件、IDE配置、日志文件
# ============================================
